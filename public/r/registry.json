    {
      "name": "glitch-split",
      "type": "registry:ui",
      "title": "Glitch Split",
      "description": "RGB-channel-split glitch effect via twin pseudo-elements with clip-path. Loop or hover trigger.",
      "files": [
        {
          "path": "registry/default/glitch-split/glitch-split.tsx",
          "type": "registry:ui",
          "target": "components/trickle/glitch-split.tsx"
        }
      ],
      "cssVars": {
        "theme": {
          "--animate-trickle-glitch-a": "trickle-glitch-a 3s steps(1) infinite",
          "--animate-trickle-glitch-b": "trickle-glitch-b 3s steps(1) infinite"
        }
      },
      "css": {
        ".trickle-glitch-split::before, .trickle-glitch-split::after": {
          "content": "attr(data-text)",
          "position": "absolute",
          "inset": "0",
          "pointer-events": "none",
          "opacity": "0"
        },
        ".trickle-glitch-split::before": { "color": "var(--trickle-glitch-a, oklch(75% 0.22 200))" },
        ".trickle-glitch-split::after": { "color": "var(--trickle-glitch-b, oklch(70% 0.27 320))" },
        ".trickle-glitch-loop::before": { "animation": "trickle-glitch-a 3s steps(1) infinite" },
        ".trickle-glitch-loop::after": { "animation": "trickle-glitch-b 3s steps(1) infinite" },
        ".trickle-glitch-split:hover::before": { "animation": "trickle-glitch-a 0.4s steps(1) 1" },
        ".trickle-glitch-split:hover::after": { "animation": "trickle-glitch-b 0.4s steps(1) 1" },
