      "css": {
        "@keyframes trickle-cascade": {
          "from": { "opacity": "0", "transform": "translateY(0.5em)" },
          "to": { "opacity": "1", "transform": "translateY(0)" }
        },
        "@media (prefers-reduced-motion: reduce)": {
          ".animate-trickle-cascade": {
            "animation": "none",
            "opacity": "1",
            "transform": "none"
          }
        }
      }
    },
    {
      "name": "char-stagger",
      "type": "registry:ui",
      "title": "Char Stagger",
      "description": "Per-character reveal with fade or slide modes. Tighter rhythm than word-cascade.",
      "files": [
        {
          "path": "registry/default/char-stagger/char-stagger.tsx",
          "type": "registry:ui",
          "target": "components/trickle/char-stagger.tsx"
        }
      ],
      "cssVars": {
        "theme": {
          "--animate-trickle-stagger-fade": "trickle-stagger-fade 0.5s ease-out both",
          "--animate-trickle-stagger-slide": "trickle-stagger-slide 0.6s cubic-bezier(0.16, 1, 0.3, 1) both"
        }
      },
      "css": {
        "@keyframes trickle-stagger-fade": {
          "from": { "opacity": "0" },
          "to": { "opacity": "1" }
        },
        "@keyframes trickle-stagger-slide": {
          "from": { "opacity": "0", "transform": "translateY(0.4em)" },
          "to": { "opacity": "1", "transform": "translateY(0)" }
        },
        "@media (prefers-reduced-motion: reduce)": {
          ".animate-trickle-stagger-fade, .animate-trickle-stagger-slide": {
            "animation": "none",
            "opacity": "1",
            "transform": "none"
          }
        }
      }
    },
    {
      "name": "gradient-shift",
      "type": "registry:ui",
      "title": "Gradient Shift",
      "description": "Animated gradient bg-clip-text. Rotates the gradient angle smoothly via @property.",
      "files": [
        {
          "path": "registry/default/gradient-shift/gradient-shift.tsx",
          "type": "registry:ui",
          "target": "components/trickle/gradient-shift.tsx"
        }
      ],
      "cssVars": {
        "theme": {
          "--animate-trickle-gradient-shift": "trickle-gradient-shift 6s linear infinite"
        }
      },
      "css": {
        "@property --trickle-gradient-angle": {
          "syntax": "\"<angle>\"",
          "initial-value": "0deg",
          "inherits": "false"
        },
        "@keyframes trickle-gradient-shift": {
          "to": { "--trickle-gradient-angle": "360deg" }
        },
        "@media (prefers-reduced-motion: reduce)": {
          ".animate-trickle-gradient-shift": { "animation": "none" }
        }
      }
    },
    {
      "name": "shiny-shimmer",
