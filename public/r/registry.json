    {
      "name": "neon-flicker",
      "type": "registry:ui",
      "title": "Neon Flicker",
      "description": "Neon glow with irregular flicker. Pure CSS, infinite loop.",
      "files": [
        {
          "path": "registry/default/neon-flicker/neon-flicker.tsx",
