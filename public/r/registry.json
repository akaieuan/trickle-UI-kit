{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "trickle",
  "homepage": "https://trickle.dev",
  "items": [
    {
      "name": "text-root",
      "type": "registry:hook",
      "title": "TextRoot",
      "description": "Hydration-safe orchestration shell for trickle text animations. Handles 'mount' / 'view' triggers, delay, and prefers-reduced-motion. Required by every other trickle component.",
      "files": [
        {
          "path": "registry/default/text-root/text-root.tsx",
          "type": "registry:hook",
          "target": "components/trickle/text-root.tsx"
        }
      ]
    },
    {
      "name": "highlighter-sweep",
      "type": "registry:ui",
      "title": "Highlighter Sweep",
      "description": "Sequential word highlight reveal driven by a CSS background-size keyframe.",
      "files": [
        {
          "path": "registry/default/highlighter-sweep/highlighter-sweep.tsx",
          "type": "registry:ui",
          "target": "components/trickle/highlighter-sweep.tsx"
        }
      ],
      "cssVars": {
        "theme": {
          "--animate-trickle-highlighter-sweep": "trickle-highlighter-sweep 0.35s ease-out both"
        }
      },
      "css": {
        "@keyframes trickle-highlighter-sweep": {
          "0%": { "background-size": "0% 100%" },
          "100%": { "background-size": "100% 100%" }
        },
        ".trickle-highlight-word": {
          "--trickle-hl": "oklch(80% 0.18 80 / 0.45)",
          "padding": "0 0.125rem",
          "margin": "0 -0.125rem",
          "border-radius": "0.125rem",
          "box-decoration-break": "clone",
          "-webkit-box-decoration-break": "clone",
          "background-image": "linear-gradient(to right, var(--trickle-hl), var(--trickle-hl))",
          "background-repeat": "no-repeat",
          "background-position": "left center",
          "background-size": "0% 100%"
        },
        "@media (prefers-reduced-motion: reduce)": {
          ".animate-trickle-highlighter-sweep": {
            "animation": "none",
            "background-size": "100% 100%"
          }
        }
      }
    },
    {
      "name": "typo-correct",
      "type": "registry:ui",
      "title": "Typo Correct",
      "description": "A word flies in chaotically, lands misspelled, then corrects itself character-by-character.",
      "registryDependencies": ["@trickle/text-root"],
      "files": [
        {
          "path": "registry/default/typo-correct/typo-correct.tsx",
          "type": "registry:ui",
          "target": "components/trickle/typo-correct.tsx"
        }
      ],
      "cssVars": {
        "theme": {
          "--animate-trickle-letter-fly-1": "trickle-letter-fly-1 1s cubic-bezier(0.34, 1.56, 0.64, 1) forwards",
          "--animate-trickle-letter-fly-2": "trickle-letter-fly-2 1s cubic-bezier(0.34, 1.56, 0.64, 1) forwards",
          "--animate-trickle-letter-fly-3": "trickle-letter-fly-3 1s cubic-bezier(0.34, 1.56, 0.64, 1) forwards",
          "--animate-trickle-letter-fly-4": "trickle-letter-fly-4 1s cubic-bezier(0.34, 1.56, 0.64, 1) forwards",
          "--animate-trickle-letter-land": "trickle-letter-land 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) forwards",
          "--animate-trickle-precise": "trickle-precise 0.4s cubic-bezier(0.16, 1, 0.3, 1) both"
        }
      },
      "css": {
        "@keyframes trickle-letter-fly-1": {
          "0%": { "transform": "translate(-200px, -120px) rotate(-180deg)", "opacity": "0" },
          "60%": { "opacity": "1" },
          "100%": { "transform": "translate(0, 0) rotate(0)", "opacity": "1" }
        },
        "@keyframes trickle-letter-fly-2": {
          "0%": { "transform": "translate(180px, 90px) rotate(220deg)", "opacity": "0" },
          "60%": { "opacity": "1" },
          "100%": { "transform": "translate(0, 0) rotate(0)", "opacity": "1" }
        },
        "@keyframes trickle-letter-fly-3": {
          "0%": { "transform": "translate(-150px, 100px) rotate(150deg)", "opacity": "0" },
          "60%": { "opacity": "1" },
          "100%": { "transform": "translate(0, 0) rotate(0)", "opacity": "1" }
        },
        "@keyframes trickle-letter-fly-4": {
          "0%": { "transform": "translate(220px, -80px) rotate(-200deg)", "opacity": "0" },
          "60%": { "opacity": "1" },
          "100%": { "transform": "translate(0, 0) rotate(0)", "opacity": "1" }
        },
        "@keyframes trickle-letter-land": {
          "0%": { "transform": "translateY(-4px)" },
          "60%": { "transform": "translateY(2px)" },
          "100%": { "transform": "translateY(0)" }
        },
        "@keyframes trickle-precise": {
          "0%": { "opacity": "0", "transform": "scale(0.5)" },
          "40%": { "opacity": "0.3", "transform": "scale(0.8)" },
          "70%": { "opacity": "0.8", "transform": "scale(1.05)" },
          "100%": { "opacity": "1", "transform": "scale(1)" }
        },
        "@media (prefers-reduced-motion: reduce)": {
          "[class*=\"animate-trickle-letter-fly\"], .animate-trickle-letter-land, .animate-trickle-precise": {
            "animation": "none",
            "opacity": "1",
            "transform": "none"
          }
        }
      }
    },
    {
      "name": "text-reveal",
      "type": "registry:ui",
      "title": "Text Reveal",
      "description": "Fade-up, blur, slide, or scale reveal. Optionally split by word or character for staggered effect.",
      "files": [
        {
          "path": "registry/default/text-reveal/text-reveal.tsx",
          "type": "registry:ui",
          "target": "components/trickle/text-reveal.tsx"
        }
      ],
      "cssVars": {
        "theme": {
          "--animate-trickle-fade-up": "trickle-fade-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) both",
          "--animate-trickle-fade-blur": "trickle-fade-blur 0.7s cubic-bezier(0.16, 1, 0.3, 1) both",
          "--animate-trickle-fade-slide": "trickle-fade-slide 0.6s cubic-bezier(0.16, 1, 0.3, 1) both",
          "--animate-trickle-fade-scale": "trickle-fade-scale 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both"
        }
      },
      "css": {
        "@keyframes trickle-fade-up": {
          "from": { "opacity": "0", "transform": "translateY(20px)" },
          "to": { "opacity": "1", "transform": "translateY(0)" }
        },
        "@keyframes trickle-fade-blur": {
          "from": { "opacity": "0", "filter": "blur(12px)" },
          "to": { "opacity": "1", "filter": "blur(0)" }
        },
        "@keyframes trickle-fade-slide": {
          "from": { "opacity": "0", "transform": "translateX(-24px)" },
          "to": { "opacity": "1", "transform": "translateX(0)" }
        },
        "@keyframes trickle-fade-scale": {
          "from": { "opacity": "0", "transform": "scale(0.8)" },
          "to": { "opacity": "1", "transform": "scale(1)" }
        },
        "@media (prefers-reduced-motion: reduce)": {
          ".animate-trickle-fade-up, .animate-trickle-fade-blur, .animate-trickle-fade-slide, .animate-trickle-fade-scale": {
            "animation": "none",
            "opacity": "1",
            "transform": "none",
            "filter": "none"
          }
        }
      }
    },
    {
      "name": "typewriter",
      "type": "registry:ui",
      "title": "Typewriter",
      "description": "Character-by-character typing with optional blinking caret and multi-string cycling.",
      "registryDependencies": ["@trickle/text-root"],
      "files": [
        {
          "path": "registry/default/typewriter/typewriter.tsx",
          "type": "registry:ui",
          "target": "components/trickle/typewriter.tsx"
