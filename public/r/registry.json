        }
      }
    },
    {
      "name": "ink-bleed",
      "type": "registry:ui",
      "title": "Ink Bleed",
      "description": "Text reveals via a radial-gradient mask animation — like ink bleeding into paper.",
      "files": [
        {
          "path": "registry/default/ink-bleed/ink-bleed.tsx",
          "type": "registry:ui",
          "target": "components/trickle/ink-bleed.tsx"
        }
      ],
      "cssVars": {
        "theme": {
          "--animate-trickle-ink-bleed": "trickle-ink-bleed 1.2s cubic-bezier(0.4, 0, 0.2, 1) both"
        }
      },
      "css": {
        "@keyframes trickle-ink-bleed": {
          "from": {
            "-webkit-mask-image": "radial-gradient(circle at 0% 50%, black 0%, transparent 0%)",
            "mask-image": "radial-gradient(circle at 0% 50%, black 0%, transparent 0%)"
          },
          "to": {
            "-webkit-mask-image": "radial-gradient(circle at 50% 50%, black 100%, transparent 130%)",
            "mask-image": "radial-gradient(circle at 50% 50%, black 100%, transparent 130%)"
          }
        },
        "@media (prefers-reduced-motion: reduce)": {
