      }
    },
    {
      "name": "underline-draw",
      "type": "registry:ui",
      "title": "Underline Draw",
      "description": "Animated underline that draws left-to-right via background-size.",
      "files": [
        {
          "path": "registry/default/underline-draw/underline-draw.tsx",
          "type": "registry:ui",
          "target": "components/trickle/underline-draw.tsx"
        }
      ],
      "cssVars": {
