            "animation": "none",
            "-webkit-mask-image": "none",
            "mask-image": "none"
          }
        }
      }
    },
    {
      "name": "paper-fold",
      "type": "registry:ui",
      "title": "Paper Fold",
      "description": "Letters fold open via 3D rotateX with parent perspective. Best for short strings.",
