      "files": [
        {
          "path": "registry/default/echo/echo.tsx",
          "type": "registry:ui",
          "target": "components/trickle/echo.tsx"
        }
      ],
      "cssVars": {
        "theme": {
          "--animate-trickle-echo": "trickle-echo 1.4s ease-out infinite"
        }
      },
      "css": {
        "@keyframes trickle-echo": {
          "0%": { "opacity": "var(--trickle-echo-opacity, 0.5)", "transform": "translate(0, 0)" },
          "100%": { "opacity": "0", "transform": "translate(var(--trickle-echo-x, 12px), var(--trickle-echo-y, 0))" }
        },
        "@media (prefers-reduced-motion: reduce)": {
