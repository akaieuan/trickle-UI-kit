        "@media (prefers-reduced-motion: reduce)": {
          ".animate-trickle-caret-blink": {
            "animation": "none",
            "opacity": "1"
          }
        }
      }
    },
    {
      "name": "word-cascade",
      "type": "registry:ui",
      "title": "Word Cascade",
      "description": "Words slide in from below, staggered. Reads like a careful reveal of a sentence.",
      "files": [
        {
          "path": "registry/default/word-cascade/word-cascade.tsx",
