{
  "name": "trickle",
  "version": "0.1.0",
  "private": true,
  "description": "Pure-CSS text animations for React. Zero runtime, SSR-safe, shadcn-style copy-paste registry.",
  "license": "MIT",
  "homepage": "https://tricklekit.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/akaieuan/trickle-UI-kit"
  },
  "scripts": {
    "dev": "next dev",
    "build": "pnpm registry:build && next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "registry:build": "shadcn build",
    "registry:validate": "tsx scripts/validate-registry.ts",
    "new": "tsx scripts/new-component.ts",
    "changeset": "changeset",
    "version": "changeset version"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "fumadocs-core": "^16.8.5",
    "fumadocs-mdx": "^14.3.2",
    "fumadocs-ui": "^16.8.5",
    "lucide-react": "^1.14.0",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@next/eslint-plugin-next": "^16.2.4",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^10.2.1",
    "eslint-config-next": "^16.2.4",
    "shadcn": "^4.6.0",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "zod": "^4.4.1"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.4.1"
}
